{
  "name": "smart-invoice-pro",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@mui/x-data-grid": "^8.10.2",
    "@tanstack/react-query": "^5.100.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.8.4",
    "chart.js": "^4.5.1",
    "firebase": "^12.12.1",
    "framer-motion": "^12.33.0",
    "history": "^5.3.0",
    "i18next": "23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.75.0",
    "react-i18next": "15.4.1",
    "react-router-dom": "^7.5.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.1.2",
    "tough-cookie": "^5.1.2",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "node scripts/patch-mui-chip.js",
    "qa": "node qa/engine/index.js",
    "qa:list": "node qa/engine/index.js list",
    "qa:parse": "node qa/engine/index.js parse",
    "qa:run": "node qa/engine/index.js run",
    "qa:login": "node qa/engine/index.js session login",
    "qa:regression": "node qa/engine/index.js regression",
    "qa:verify": "node qa/engine/index.js verify-browser",
    "qa:validate": "node qa/engine/index.js validate",
    "qa:data": "node qa/engine/index.js test-data",
    "qa:bug": "node qa/engine/index.js bug",
    "qa:compare": "node qa/engine/index.js compare",
    "qa:seed-excel": "node qa/scripts/seed-excel.js",
    "qa:playwright": "playwright test -c qa/configs/playwright.config.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "nth-check": "^2.0.1",
    "svgo": "^3.0.0"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|react-router|react-router-dom)/)"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss)$": "<rootDir>/src/__mocks__/styleMock.js",
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js"
    },
    "coverageThreshold": {
      "./src/services/": {
        "statements": 80,
        "functions": 80,
        "lines": 80
      },
      "./src/components/common/": {
        "statements": 70,
        "functions": 70,
        "lines": 70
      },
      "./src/components/Auth/": {
        "statements": 70,
        "functions": 60,
        "lines": 70
      },
      "./src/pages/Dashboard.jsx": {
        "statements": 70,
        "functions": 70,
        "lines": 70
      },
      "./src/admin/services/": {
        "statements": 80,
        "functions": 80,
        "lines": 80
      },
      "./src/admin/routes/": {
        "statements": 60,
        "functions": 50,
        "lines": 60
      },
      "./src/admin/pages/": {
        "statements": 20,
        "functions": 15,
        "lines": 20
      },
      "./src/admin/components/": {
        "statements": 70,
        "functions": 60,
        "lines": 70
      },
      "./src/context/": {
        "statements": 50,
        "functions": 40,
        "lines": 50
      },
      "./src/config/": {
        "statements": 50,
        "lines": 50
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0"
  }
}
